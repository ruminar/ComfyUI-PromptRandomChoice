# --- Python関連 ---
# これがJavaの.classに近いものじゃ。実行時に自動生成される。
__pycache__/
*.py[cod]
*$py.class

# 仮想環境（もしプロジェクト内に作っておるなら）
venv/
.venv/
env/

# --- エディタ・OS関連 ---
# VS Codeの設定ファイル（個人設定が含まれることがあるので除外）
.vscode/
# macOSが勝手に作るゴミ
.DS_Store
# Windowsのサムネイルキャッシュ
Thumbs.db

# --- ComfyUI/カスタムノード特有 ---
# もし一時ファイルやログを書き出す仕組みを作ったなら、それも追加じゃ
*.log
